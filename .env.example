OPENAI_API_KEY=your_openai_api_key_here
SECRET_KEY=replace-with-a-long-random-value
# Leave empty for same-origin Socket.IO. Use a comma-separated list only when
# trusted external browser origins need direct Socket.IO access.
SOCKETIO_CORS_ORIGINS=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
MAX_UPLOAD_BYTES=2097152
# Keep production quiet. Set true only when diagnosing Socket.IO/log ingestion.
ENABLE_DEBUG_TOOLS=false
